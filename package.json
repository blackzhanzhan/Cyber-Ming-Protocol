{
  "name": "@blackzhanzhan/cyber-ming",
  "version": "0.2.0-beta.5",
  "description": "Installer, starter, and runtime-governance bundle for Cyber-Ming Protocol skills.",
  "bin": {
    "cyber-ming": "bin/cyber-ming.js"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18.17.0"
  },
  "files": [
    "bin",
    "installer",
    "skill",
    "!skill/**/__pycache__/**",
    "!skill/**/*.pyc",
    "starter",
    "BOOTSTRAP.md",
    "bootstrap",
    "web-audit-templates",
    "dev_repo/README.md",
    "dev_repo/architecture",
    "scripts/validate_dev_repo_runtime.py"
  ],
  "scripts": {
    "cyber-ming": "node bin/cyber-ming.js",
    "doctor": "node bin/cyber-ming.js doctor",
    "runtime:validate": "python scripts/validate_dev_repo_runtime.py",
    "site:validate": "node site/scripts/validate-content-manifest.mjs",
    "site:build": "node site/scripts/build-static-wiki.mjs",
    "site:check": "node site/scripts/validate-content-manifest.mjs && node site/scripts/build-static-wiki.mjs && node site/scripts/validate-dist.mjs"
  },
  "keywords": [
    "ai-coding",
    "agent-governance",
    "claude-code",
    "codex",
    "cursor",
    "opencode",
    "contract-hooks",
    "architecture-governance",
    "data-model",
    "er-diagrams",
    "cli",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackzhanzhan/Cyber-Ming-Protocol.git"
  },
  "bugs": {
    "url": "https://github.com/blackzhanzhan/Cyber-Ming-Protocol/issues"
  },
  "homepage": "https://github.com/blackzhanzhan/Cyber-Ming-Protocol#readme",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
